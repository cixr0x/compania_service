# Copy this file to backend/.env and replace every placeholder.
# backend/.env is gitignored and should contain the real credentials.
#
# DATABASE_URL is the value used by Prisma and the NestJS backend.
# Format:
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# If the password contains special characters such as @, :, /, ?, #, or &,
# URL-encode them before putting them in DATABASE_URL.
DATABASE_URL="mysql://<mysql_user>:<mysql_password>@<mysql_host>:3306/<database_name>"

# Reference fields for humans/operators. Keep these aligned with DATABASE_URL.
MYSQL_HOST="<mysql_host>"
MYSQL_PORT="3306"
MYSQL_DATABASE="<database_name>"
MYSQL_USER="<mysql_user>"
MYSQL_PASSWORD="<mysql_password>"

# Backend runtime.
PORT="3000"
# Optional. Comma-separate frontend origins. If omitted, the backend allows common local Vite origins on localhost/127.0.0.1 ports 5173-5175.
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175"
