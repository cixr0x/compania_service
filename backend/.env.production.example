# Copy this file to backend/.env on the production VM and replace every placeholder.
# backend/.env is gitignored and must contain the real credentials.

# Prisma and NestJS database connection.
# Format:
# mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# If the password contains special characters such as @, :, /, ?, #, or &,
# URL-encode them before putting them in DATABASE_URL.
DATABASE_URL="mysql://<mysql_user>:<mysql_password>@<mysql_host>:3306/<database_name>"

# Backend runtime.
NODE_ENV="production"
PORT="3000"

# Public frontend origin. Use one origin for production, for example:
# https://app.example.com
CORS_ORIGIN="https://your-domain.example"
